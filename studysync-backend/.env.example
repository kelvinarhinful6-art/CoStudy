# Copy this file to ".env" (already done in this project) and keep your real values here.
# Rule: secrets live here, NEVER inside Java code.

# --- PostgreSQL ---
POSTGRES_USER=studysync
POSTGRES_PASSWORD=studysync_pass
POSTGRES_DB=studysync

# --- JWT (used later by auth-service to sign login tokens) ---
JWT_SECRET=change-me-to-a-long-random-secret-string-min-32-chars
JWT_EXP_MIN=15
